generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Project {
  id          String @id
  title       String
  subtitle    String
  cat         String
  status      String
  nodesOnline Int    @default(0)
  nodesTotal  Int    @default(1)
  icon        String
}

model Contact {
  id               Int      @id @default(autoincrement())
  name             String
  contact_no       String
  institution      String?
  deadline         String
  description      String?
  perf_expectation String?
  created_at       DateTime @default(now())
}

model Report {
  id               Int      @id @default(autoincrement())
  name             String
  contact_no       String
  institution      String?
  deadline         String
  description      String?
  format           String
  way_to_make      String
  performance_tier String
  file_path        String?
  created_at       DateTime @default(now())
}

model Learning {
  id               Int      @id @default(autoincrement())
  name             String
  contact_no       String
  institution      String?
  preferred_date   String
  topics           String
  created_at       DateTime @default(now())
}
